# ==========================================
# UDR Test Server Configuration
# ==========================================

# Port for the UDR Mock Server (HTTP/REST interface)
PORT=8080

# Connection URI for MongoDB
MONGODB_URI=mongodb://localhost:27017

# Default MongoDB Database name
MONGODB_DB=udr


# ==========================================
# MCP MongoDB Server Configuration
# ==========================================

# Transport type: 'stdio' (for local client subprocesses) or 'sse' (for remote web server)
MCP_TRANSPORT=stdio

# Port for the MCP Server (used ONLY when MCP_TRANSPORT=sse)
# Note: Keep this different from the UDR Mock Server PORT to prevent conflicts.
# PORT=8081
